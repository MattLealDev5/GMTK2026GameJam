// if you don't set the speed in the script, it'll be this instead
speed = 1;
speedInitial = speed;

colorMid = #FFFFFF;
colorFinal = #FFFFFF;

// for scaling certain properties of the particle
scaleScale = 1;

instant = false;

alarm_set(0,4);

// used in an if() to make it move in a random direction or not
burst = false;

